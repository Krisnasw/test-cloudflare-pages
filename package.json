{
  "name": "react-vite-cf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.2.15",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && bun scripts/generate-pages-vite-manifest.ts",
    "preview": "vite preview",
    "pages:dev": "bun run build && npx wrangler pages dev dist/client",
    "pages:deploy": "bun run build && npx wrangler pages deploy dist/client --project-name react-vite-cf",
    "deploy": "bun run pages:deploy"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.167.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260316.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.6.3",
    "vite": "^6.4.1",
    "wrangler": "^4.74.0"
  }
}
